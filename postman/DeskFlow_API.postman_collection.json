          "name": "Employee Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "if (response.token) {\r",
                  "  pm.environment.set(\"employeeToken\", response.token);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"nkululeko.mahlangu@deskflow.com\",\r\n  \"password\": \"nkululeko123\",\r\n  \"role\": \"Employee\"\r\n}",
